  questTitle: "The New Battlefield"
  questDescription: "Maria has pushed forward to a new front line. The Paladin says
    she needs backup — use the teleport and head out to support her."
  steps:
  - stepTitle: "Talk with the Paladin"
    instruction: "Speak with the Paladin at the City Gate. He knows where Maria went."
    targetTag: NPC_Paladin
    targetSceneName: 
  - stepTitle: "Find the teleport point"
    instruction: "Head to the nearby teleport to reach the new battlefield."
    targetTag: TeleportPoint_Battlefield
    targetSceneName: 
  - stepTitle: "Use the teleport"
    instruction: "Step into the teleport — it will take you to the new battlefield."
    targetTag: TeleportPoint_Battlefield
    targetSceneName: 
  - stepTitle: "Find and talk with Leona"
    instruction: "Locate Leona at the new battlefield and speak with her."
    targetTag: NPC_Leona
    targetSceneName: 
  - stepTitle: "Enter the dungeon gate"
    instruction: "Enter the dungeon gate Leona is guarding. The battle awaits inside."
    targetTag: DungeonGate2
